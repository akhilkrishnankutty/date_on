        u1_0.bio,
        u1_0.compatibility_score,
        u1_0.custom_question,
        u1_0.dob,
        u1_0.gender,
        u1_0.interests,
        u1_0.is_paused,
        u1_0.location,
        u1_0."lock",
        u1_0.loid,
        u1_0.mail,
        u1_0.match_cooldown_until,
        u1_0.match_time,
        u1_0.name,
        u1_0.number,
        u1_0.password,
        u1_0.past_matches,
        u1_0.profile_picture,
        u1_0.profile_picture_content_type,
        u1_0.status,
        u1_0.workplace 
    from
        users u1_0 
    where
        u1_0.gender<>? 
        and u1_0."lock"=false 
        and u1_0.is_paused=false 
        and u1_0.id not in (?, ?) 
    order by
        abs((u1_0.compatibility_score-?))
